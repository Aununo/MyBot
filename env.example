# Auto-generated for local NapCat reverse WS deployment
# NoneBot 基础配置
# 运行环境：dev 开发环境，prod 生产环境
ENVIRONMENT=prod

# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# NoneBot 监听配置
HOST=0.0.0.0
PORT=8080

# OneBot V11 适配器配置
# 当前推荐由 NapCat 使用 reverse WebSocket 主动连接到本 Bot。
# 这里通常可留空；真正的连接地址在 NapCat 侧填写：ws://127.0.0.1:8080/onebot/v11/ws
ONEBOT_WS_URLS=[]

# 超级用户 QQ 号（管理员，可以有多个）
# 格式：["123456789", "987654321"]
SUPERUSERS=[]

# 命令前缀（触发命令的符号）
COMMAND_START=["/"]

# 天气插件 API Key
# 在 https://openweathermap.org/api 注册获取
# 注意：需要订阅 One Call API 3.0（前 1000 次调用/天免费）
WEATHER_API_KEY=your_openweathermap_api_key_here

# B 站视频解析（可选，用于直链）
# 在浏览器登录 bilibili.com 后，从 Cookies 中获取
BILI_SESSDATA=your_bili_sessdata_here
BILI_BILI_JCT=your_bili_jct_here
BILI_DEDEUSERID=your_bili_dedeuserid_here

# B 站代理播放链接（可选）
# 例：https://your-host:8000 （需对外可访问）
BILI_PROXY_BASE_URL=https://your-host:8000
# 独立 B 站代理服务监听地址（通常只监听本机，由反代对外暴露）
BILI_PROXY_HOST=127.0.0.1
BILI_PROXY_PORT=8091
# 是否强制使用 https（未填写协议时默认 https）
BILI_PROXY_FORCE_HTTPS=true
BILI_PROXY_TTL=3600

# 邮箱通知配置
# IMAP 服务器地址 (例如: imap.gmail.com, imap.qq.com)
EMAIL_IMAP_SERVER=imap.example.com
# IMAP 端口 (通常是 993 SSL)
EMAIL_IMAP_PORT=993
# 邮箱账号
EMAIL_USER=your_email@example.com
# 邮箱密码 (对于 Gmail/QQ 等通常需要使用应用专用密码)
EMAIL_PASSWORD=your_app_password

# OpenClaw Bridge（使 QQ 机器人可把消息桥接到 OpenClaw）
OPENCLAW_AGENT_ID=main
OPENCLAW_BRIDGE_USE_LOCAL=true
OPENCLAW_BRIDGE_TIMEOUT=180
OPENCLAW_BRIDGE_THINKING=medium
OPENCLAW_SESSION_MODE=ephemeral
OPENCLAW_IMAGE_MODE=true
OPENCLAW_AUDIO_MODE=true
OPENCLAW_AUDIO_MODEL=small
OPENCLAW_AUDIO_TRANSCRIBE_TIMEOUT=180
# 可选：覆盖数据目录（默认 /app/data 或 <repo>/data）
# QQ_DATA_DIR=/path/to/data

# 运维告警配置
OPS_ALERT_ENABLED=true
OPS_ALERT_GROUP_ID=
OPS_ALERT_AT_USERS=
OPS_ALERT_CHECK_INTERVAL_SECONDS=60
OPS_ALERT_OPENCLAW_CHECK_INTERVAL_SECONDS=180
OPS_ALERT_CPU_THRESHOLD=95
OPS_ALERT_MEMORY_THRESHOLD=90
OPS_ALERT_DISK_THRESHOLD=90
OPS_ALERT_CONSECUTIVE_FAILURES=2
OPS_ALERT_OPENCLAW_TIMEOUT_SECONDS=20
OPS_ALERT_WATCHDOG_EVENTS_FILE=/path/to/ops_watchdog_events.jsonl
